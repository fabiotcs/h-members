# ============================================
# H-Members Platform - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# App Core
# --------------------------------------------
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# License key for software activation (optional — future feature)
LICENSE_KEY=

# --------------------------------------------
# Database (MySQL / MariaDB)
# --------------------------------------------
# Full connection string used by Prisma
DATABASE_URL=mysql://hmembers:YOUR_PASSWORD@localhost:3306/hmembers

# --------------------------------------------
# Authentication & Security
# --------------------------------------------
# JWT secret for login tokens (generate a strong random string)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Admin credentials (created on first run)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=CHANGE_ME

# Max simultaneous sessions per user (anti-sharing)
MAX_SESSIONS=1

# Secret for validating incoming webhooks
WEBHOOK_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# --------------------------------------------
# SMTP (Transactional Emails — optional)
# --------------------------------------------
# If not configured, the system will start but email sending will be unavailable
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@seudominio.com

# --------------------------------------------
# White Label / Customization
# --------------------------------------------
# These values serve as defaults. They can be overridden
# via the admin panel (stored in the PlatformSetting DB table).
PLATFORM_NAME=H-Members
PRIMARY_COLOR=#6366F1
LOGO_URL=
FAVICON_URL=

# --------------------------------------------
# File Storage
# --------------------------------------------
# Local storage path for uploads
UPLOAD_DIR=./uploads
# Max upload size in bytes (default: 52428800 = 50 MB)
MAX_UPLOAD_SIZE=52428800
