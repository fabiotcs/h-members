# ============================================
# H-Members Platform - .gitignore
# ============================================

# Environment & Secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Dependencies
node_modules/

# Build & Logs
dist/
build/
*.log
logs/

# IDE & OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# AIOX Local
.aiox-core/local/
.claude/settings.local.json
.aiox/install-log.txt

# Docker
docker-compose.override.yml

# Database
mysql_data/
db_data/
*.sql.gz

# Uploads (local file storage - like wp-content)
uploads/*
!uploads/.gitkeep

# Coverage & Tests
coverage/
.nyc_output/

# Temp files
tmp/
temp/
*.tmp
